# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here   # server only — never NEXT_PUBLIC_

# ── Cloudinary ────────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=tonmai_unsigned    # create as unsigned preset

# ── Resend ────────────────────────────────────────────────────
RESEND_API_KEY=re_your_key_here
RESEND_FROM=hello@tonmaispa.com                         # must be a verified domain in Resend
RESEND_TEST_TO=dev@yourmail.com                         # REMOVE THIS IN PRODUCTION
INQUIRY_EMAIL=owner@tonmaispa.com

# ── MiniMax (AI Chatbot) ──────────────────────────────────────
MINIMAX_API_KEY=your_minimax_api_key                    # server only — NEVER NEXT_PUBLIC_

# ── Google Analytics ──────────────────────────────────────────
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Rate Limiting (Upstash Redis) ─────────────────────────────
UPSTASH_REDIS_REST_URL=https://YOUR_URL.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# ── Cloudflare Turnstile (CAPTCHA) ────────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA...            # public — visible to browser
TURNSTILE_SECRET_KEY=0x4AAAAAAA...                     # server only

# ── Site Config ───────────────────────────────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER=66631175211                 # without + for wa.me
NEXT_PUBLIC_LINE_ID=@tonmaispa
NEXT_PUBLIC_SITE_URL=http://localhost:3000              # change to https://www.tonmaispa.com in prod
