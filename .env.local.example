# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here   # server only — never NEXT_PUBLIC_

# ── Cloudinary ────────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=tonmai_unsigned    # create as unsigned preset

# ── Brevo (transactional email) ───────────────────────────────
BREVO_API_KEY=xkeysib-your_key_here
BREVO_FROM=Ton Mai Spa <hello@tonmaispa.com>            # sender must be verified in Brevo
EMAIL_TEST_TO=dev@yourmail.com                          # REMOVE THIS IN PRODUCTION
INQUIRY_EMAIL=owner@tonmaispa.com

# ── MiniMax (AI Chatbot) ──────────────────────────────────────
MINIMAX_API_KEY=your_minimax_api_key                    # server only — NEVER NEXT_PUBLIC_

# ── Twilio WhatsApp ───────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=your_api_key_secret               # server only
TWILIO_AUTH_TOKEN=your_auth_token                       # webhook validation only
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886              # sandbox sender; switch to whatsapp:+66822866058 after Twilio/Meta approval
TWILIO_STATUS_CALLBACK_URL=https://your-domain.com/api/twilio/whatsapp/status
TWILIO_WEBHOOK_BASE_URL=https://your-domain.com         # exact public base URL Twilio calls
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Scheduled Jobs ───────────────────────────────────────────
CRON_SECRET=generate_a_long_random_secret_for_vercel_cron
BOOKING_REQUEST_SECRET=optional_separate_secret_for_whatsapp_booking_links
BOOKING_LOOKUP_SECRET=optional_separate_secret_for_booking_email_codes

# ── Google Analytics ──────────────────────────────────────────
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Rate Limiting (Upstash Redis) ─────────────────────────────
UPSTASH_REDIS_REST_URL=https://YOUR_URL.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# ── Cloudflare Turnstile (CAPTCHA) ────────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA...            # public — visible to browser
TURNSTILE_SECRET_KEY=0x4AAAAAAA...                     # server only

# ── Site Config ───────────────────────────────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER=66822866058                 # official WhatsApp, without + for wa.me
NEXT_PUBLIC_LINE_ID=@tonmaispa
NEXT_PUBLIC_SITE_URL=http://localhost:3000              # change to https://www.tonmaispa.com in prod
